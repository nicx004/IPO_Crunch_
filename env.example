# ── Required: at least one of these ──────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENAI_API_KEY=your_openai_key_here

# ── Model (OpenRouter free models that work well) ─────────────────────────────
LLM_MODEL=deepseek/deepseek-chat-v3-0324:free
LLM_BASE_URL=https://openrouter.ai/api/v1

# ── Data paths (leave as defaults) ────────────────────────────────────────────
IPO_DATA_DIR=./ipo_data

# ── Security / deployment ─────────────────────────────────────────────────────
# Optional: protect POST /api/refresh by requiring this header value:
# X-Refresh-Token: <REFRESH_TOKEN>
REFRESH_TOKEN=

# Optional: comma-separated allowed origins.
# Example: CORS_ORIGINS=https://your-app.onrender.com,https://yourdomain.com
# If empty and running on Render, RENDER_EXTERNAL_URL is used automatically.
CORS_ORIGINS=

# ── Render sets PORT automatically — don't set this manually ──────────────────
# PORT=7860
